{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Static File Server",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "."],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "Todo App (React)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "todo-app", "run", "dev", "--", "--host"],
      "port": 5173,
      "autoPort": true
    }
  ]
}
